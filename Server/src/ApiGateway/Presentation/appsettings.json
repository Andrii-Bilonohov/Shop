{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ReverseProxy": {
    "Routes": {
      "login": {
        "ClusterId": "authorizations",
        "Match": { "Path": "/api/login" },
        "AuthorizationPolicy": "Public"
      },
      "register": {
        "ClusterId": "authorizations",
        "Match": {"Path": "/api/register"},
        "AuthorizationPolicy": "Public"
      },
      "catalog": {
        "ClusterId": "catalog",
        "Match": { "Path": "/api/items/{**catch-all}" },
        "AuthorizationPolicy": "Authenticated"
      },
      "orders": {
        "ClusterId": "orders",
        "Match": { "Path": "/api/orders/{**catch-all}" },
        "AuthorizationPolicy": "Authenticated"
      },
      "payment": {
        "ClusterId": "payments",
        "Match": { "Path": "/api/payments/{**catch-all}" },
        "AuthorizationPolicy": "Authenticated"
      }
    },
    "Clusters": {
      "authorizations": {
        "Destinations": { "d1": { "Address": "http://localhost:5002/" } }
      },
      "catalog": {
        "Destinations": { "d1": { "Address": "http://localhost:5003/" } }
      },
      "orders": {
        "Destinations": { "d1": { "Address": "http://localhost:5004/" } }
      },
      "payments": {
        "Destinations": { "d1": { "Address": "http://localhost:5005/" } }
      }
    }
  },
  "Jwt": {
    "Secret": "",
    "ExpiryMinutes": 60,
    "Issuer": "Authorization",
    "Audience": "ApiGateway"
  },
  "Gateway": {
    "HeaderName": "X-Api-Gateway",
    "Secret": ""
  }
}
