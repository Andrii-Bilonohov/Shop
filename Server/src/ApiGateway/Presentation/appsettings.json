{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ReverseProxy": {
    "Routes": {
      "login": {
        "ClusterId": "authorizations",
        "Match": { "Path": "/api/login" },
        "AuthorizationPolicy": "Public"
      },
      "register": {
        "ClusterId": "authorizations",
        "Match": { "Path": "/api/register" },
        "AuthorizationPolicy": "Public"
      },
      "catalog": {
        "ClusterId": "catalog",
        "Match": { "Path": "/api/items/{**catch-all}" },
        "AuthorizationPolicy": "Authenticated"
      },
      "orders": {
        "ClusterId": "orders",
        "Match": { "Path": "/api/orders/{**catch-all}" },
        "AuthorizationPolicy": "Authenticated"
      },
      "payment": {
        "ClusterId": "payments",
        "Match": { "Path": "/api/payments/{**catch-all}" },
        "AuthorizationPolicy": "Authenticated"
      }
    },
    "Clusters": {
      "authorizations": {
        "Destinations": {
          "authorization-service": {
            "Address": "http://authorization:8080/"
          }
        }
      },
      "catalog": {
        "Destinations": {
          "catalog-service": {
            "Address": "http://catalog:8080/"
          }
        }
      },
      "orders": {
        "Destinations": {
          "order-service": {
            "Address": "http://order:8080/"
          }
        }
      },
      "payments": {
        "Destinations": {
          "payment-service": {
            "Address": "http://payment:8080/"
          }
        }
      }
    }
  },
  "Jwt": {
    "Secret": "",
    "ExpiryMinutes": 60,
    "Issuer": "Authorization",
    "Audience": "ApiGateway"
  },

  "Gateway": {
    "HeaderName": "X-Api-Gateway",
    "Secret": ""
  }
}